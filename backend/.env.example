# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct DB connection (get from Supabase dashboard > Settings > Database)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# AI APIs
GEMINI_API_KEY=your-gemini-api-key

# App
DEBUG=true
# Local example:
# CORS_ORIGINS=http://localhost:3000
# Production example:
# CORS_ORIGINS=https://your-frontend.vercel.app
# Multiple origins may be comma-separated:
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000
